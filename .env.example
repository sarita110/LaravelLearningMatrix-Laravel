APP_NAME="Laravel Learning Matrix"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── DATABASE ──────────────────────────────────────────────────
# Default: SQLite (no server needed — great for learning)
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite
# Uncomment below for MySQL instead:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=learning_matrix
# DB_USERNAME=root
# DB_PASSWORD=

# ── SESSION & CACHE ───────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database

# ── QUEUE ─────────────────────────────────────────────────────
# Phase 6: set to "database" to use queues with the jobs table
QUEUE_CONNECTION=sync
# Change to: QUEUE_CONNECTION=database
# Then run: php artisan queue:work

# ── MAIL ──────────────────────────────────────────────────────
# Phase 6: "log" sends emails to storage/logs/laravel.log (great for local dev)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@learningmatrix.test"
MAIL_FROM_NAME="${APP_NAME}"

# ── BROADCASTING ──────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
